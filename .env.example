# ==============================================================================
# Frontend Multiverse - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
# Application title displayed in browser tab
VITE_APP_TITLE="Frontend Multiverse"

# Base URL for the application (used for routing and asset paths)
VITE_BASE_URL="/"

# ------------------------------------------------------------------------------
# Analytics (Optional)
# ------------------------------------------------------------------------------
# Google Analytics measurement ID (starts with G-)
# VITE_GA_MEASUREMENT_ID=""

# ------------------------------------------------------------------------------
# Feature Flags (Optional)
# ------------------------------------------------------------------------------
# Enable/disable debug mode (shows extra debugging info)
VITE_DEBUG_MODE="false"

# Enable/disable analytics tracking
VITE_ANALYTICS_ENABLED="false"
